{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "APK Split Extractor",
  "version": "0.2.0",
  "identifier": "local.apk-split-extractor",
  "build": {
    "beforeDevCommand": "npm run dev:frontend",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "APK Split Extractor",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
